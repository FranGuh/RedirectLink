---
import Layout from '../layouts/Layout.astro';
import ImgContainer from '../components/ImgContainer.astro';
import NavLink from '../components/NavLink.astro';
---

<Layout
  title="Gustavo Francisco | Developer Links - RedirectLink"
  description="Enlaces oficiales de Gustavo Francisco - Desarrollador Web React. Proyectos, portfolio, redes sociales y contacto profesional."
>
  <div class="app-root">
    <section class="background__content">
      <ImgContainer
        src="/images/user/fondo2.jpg"
        alt="Fondo decorativo de perfil de Gustavo Francisco"
      />
    </section>

    <main class="main__content">
      <NavLink />
    </main>
  </div>
</Layout>
